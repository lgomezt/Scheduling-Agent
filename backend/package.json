{
  "name": "scheduling-agent-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/db dist/study/prompts && cp src/db/schema.sql dist/db/ && cp src/study/study-config.json dist/study/ && cp src/study/prompts/*.md dist/study/prompts/",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.10.0",
    "cookie-session": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "googleapis": "^172.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
